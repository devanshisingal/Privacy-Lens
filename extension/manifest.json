{
  "manifest_version": 3,
  "name": "PrivacyLens",
  "version": "1.0",

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:3000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}